{
  "manifest_version": 3,
  "name": "Target Orders Extractor",
  "version": "1.0",
  "description": "Extracts and filters Target orders by date range",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.target.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.target.com/orders*"],
      "js": ["content.js"]
    }
  ]
}
