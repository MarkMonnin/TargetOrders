{
  "manifest_version": 3,
  "name": "Target Orders Extractor",
  "version": "1.0",
  "description": "Extracts and filters Target orders by date range",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.target.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.target.com/*"],
      "js": ["content-modular-v2.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "modules/*.js",
        "modules/base/*.js",
        "modules/processors/*.js"
      ],
      "matches": ["https://www.target.com/*"]
    }
  ]
}
